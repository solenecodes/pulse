generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         String    @default("client")
  passwordHash String
  sessions     Session[]
  cartItems    CartItem[]
  createdAt    DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id          String     @id
  name        String
  category    String
  priceCents  Int
  accent      String
  description String
  cartItems   CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model CodexAction {
  id        String   @id @default(cuid())
  userId    String?
  intent    String
  output    String
  createdAt DateTime @default(now())
}
